# 專案運行設定
COMPOSE_PROJECT_NAME=multimodal_rag
TZ=Asia/Taipei

# 基礎 API 服務 (apps/backend)
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True

# 前端服務 (apps/frontend)
FRONTEND_PORT=3000

# OCR/VLM 模型客戶端設定 (vLLM / Ollama)
# 支援的 MODEL_PROVIDER: vllm, ollama, glmocr
MODEL_PROVIDER=ollama
OLLAMA_ENDPOINT=http://host.docker.internal:11434
VLLM_ENDPOINT=http://host.docker.internal:8000/v1
MODEL_NAME=qwen2-vl:latest

# 向量資料庫參數 (Milvus)
MILVUS_HOST=milvus-standalone
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=

# 快取與任務庫 (Redis)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# 物件儲存 (MinIO)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
